{
  "openapi": "3.1.0",
  "info": {
    "title": "Agent Router API",
    "version": "0.1.0",
    "description": "Unified OpenAPI entrypoint for Codex, Claude, and Gemini CLIs via ACP."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8787"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Service status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/providers": {
      "get": {
        "summary": "List providers",
        "operationId": "listProviders",
        "responses": {
          "200": {
            "description": "Available providers",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProvidersResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/models": {
      "get": {
        "summary": "OpenAI-compatible models list",
        "description": "Dynamic yescode catalog merged from Codex/Claude/Gemini model sets.",
        "operationId": "listModels",
        "responses": {
          "200": {
            "description": "Available models",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/chat/completions": {
      "post": {
        "summary": "OpenAI-compatible chat completions",
        "operationId": "chatCompletions",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatCompletionsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Chat completion result or SSE stream",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatCompletionsResponse"
                }
              },
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/responses": {
      "post": {
        "summary": "OpenAI-compatible responses API",
        "operationId": "responsesApi",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResponsesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response object or SSE stream",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResponsesResult"
                }
              },
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/v1/agents/chat": {
      "post": {
        "summary": "Run one ACP prompt",
        "operationId": "chat",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Prompt result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Runtime error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/agents/chat/stream": {
      "post": {
        "summary": "Run one ACP prompt with SSE streaming",
        "operationId": "chatStream",
        "description": "Streams real-time ACP updates and token chunks as Server-Sent Events.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SSE stream with event/token/done/error frames",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Validation error before stream starts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ChatRequest": {
        "type": "object",
        "required": [
          "provider",
          "message"
        ],
        "properties": {
          "provider": {
            "type": "string",
            "enum": [
              "yescode",
              "codex",
              "claude",
              "gemini"
            ]
          },
          "message": {
            "type": "string"
          },
          "model": {
            "type": "string",
            "description": "Provider model id (for example: gpt-5-codex, sonnet, gemini-2.5-flash)."
          },
          "cwd": {
            "type": "string",
            "description": "Absolute or relative working directory for ACP session."
          },
          "timeoutMs": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3600000
          },
          "permissionMode": {
            "type": "string",
            "enum": [
              "allow",
              "reject"
            ],
            "default": "allow"
          },
          "reasoningEffort": {
            "type": "string",
            "enum": [
              "none",
              "minimal",
              "low",
              "medium",
              "high",
              "xhigh",
              "max"
            ],
            "description": "Reasoning level forwarded to Codex CLI as model_reasoning_effort."
          },
          "includeEvents": {
            "type": "boolean",
            "default": false
          },
          "apiKey": {
            "type": "string",
            "description": "co.yes.vg API key. Optional when COYES_API_KEY or X-API-Key header is set."
          }
        }
      },
      "ChatResponse": {
        "type": "object",
        "required": [
          "provider",
          "sessionId",
          "stopReason",
          "outputText",
          "elapsedMs"
        ],
        "properties": {
          "provider": {
            "type": "string"
          },
          "sessionId": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "protocolVersion": {
            "type": "integer"
          },
          "stopReason": {
            "type": "string"
          },
          "outputText": {
            "type": "string"
          },
          "elapsedMs": {
            "type": "integer"
          },
          "updates": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "stderr": {
            "type": "string"
          }
        }
      },
      "ProvidersResponse": {
        "type": "object",
        "required": [
          "providers"
        ],
        "properties": {
          "providers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ModelsResponse": {
        "type": "object",
        "required": [
          "object",
          "data"
        ],
        "properties": {
          "object": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "object"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "object": {
                  "type": "string"
                },
                "owned_by": {
                  "type": "string"
                },
                "metadata": {
                  "type": "object",
                  "properties": {
                    "provider": {
                      "type": "string"
                    },
                    "family": {
                      "type": "string"
                    },
                    "source": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "ChatCompletionsRequest": {
        "type": "object",
        "required": [
          "messages"
        ],
        "properties": {
          "model": {
            "type": "string",
            "description": "Model id, eg. co-codex/co-claude/co-gemini."
          },
          "provider": {
            "type": "string",
            "enum": [
              "yescode",
              "codex",
              "claude",
              "gemini"
            ]
          },
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "stream": {
            "type": "boolean"
          },
          "timeoutMs": {
            "type": "integer"
          },
          "permissionMode": {
            "type": "string",
            "enum": [
              "allow",
              "reject"
            ]
          },
          "reasoningEffort": {
            "type": "string",
            "enum": [
              "none",
              "minimal",
              "low",
              "medium",
              "high",
              "xhigh",
              "max"
            ]
          },
          "reasoning": {
            "type": "object",
            "properties": {
              "effort": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "apiKey": {
            "type": "string"
          }
        }
      },
      "ChatCompletionsResponse": {
        "type": "object",
        "required": [
          "id",
          "object",
          "model",
          "choices"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "object": {
            "type": "string"
          },
          "created": {
            "type": "integer"
          },
          "model": {
            "type": "string"
          },
          "choices": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      },
      "ResponsesRequest": {
        "type": "object",
        "properties": {
          "model": {
            "type": "string"
          },
          "provider": {
            "type": "string",
            "enum": [
              "yescode",
              "codex",
              "claude",
              "gemini"
            ]
          },
          "input": {
            "description": "String or structured input payload.",
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array"
              }
            ]
          },
          "stream": {
            "type": "boolean"
          },
          "reasoningEffort": {
            "type": "string",
            "enum": [
              "none",
              "minimal",
              "low",
              "medium",
              "high",
              "xhigh",
              "max"
            ]
          },
          "reasoning": {
            "type": "object",
            "properties": {
              "effort": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "apiKey": {
            "type": "string"
          }
        }
      },
      "ResponsesResult": {
        "type": "object",
        "required": [
          "id",
          "object",
          "output_text"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "object": {
            "type": "string"
          },
          "created_at": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "output_text": {
            "type": "string"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "ok",
          "service"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "service": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          },
          "details": {
            "type": "string"
          }
        }
      }
    }
  }
}
