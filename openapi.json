{
  "openapi": "3.1.0",
  "info": {
    "title": "Agent Router API",
    "version": "0.1.0",
    "description": "Local API gateway for Codex, Claude, and Gemini CLIs."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8787"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Service status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/providers": {
      "get": {
        "summary": "List providers",
        "operationId": "listProviders",
        "responses": {
          "200": {
            "description": "Available providers",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProvidersResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/models": {
      "get": {
        "summary": "OpenAI-compatible models list",
        "description": "Models currently available through CliACP (Codex, Claude, Gemini backends).",
        "operationId": "listModels",
        "responses": {
          "200": {
            "description": "Available models",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/chat/completions": {
      "post": {
        "summary": "OpenAI-compatible chat completions",
        "operationId": "chatCompletions",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatCompletionsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Chat completion result or SSE stream",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatCompletionsResponse"
                }
              },
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/responses": {
      "post": {
        "summary": "OpenAI-compatible responses API",
        "operationId": "responsesApi",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResponsesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response object or SSE stream",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResponsesResult"
                }
              },
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/v1/agents/chat": {
      "post": {
        "summary": "Run one prompt",
        "operationId": "chat",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Prompt result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Runtime error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/agents/chat/stream": {
      "post": {
        "summary": "Run one prompt with SSE streaming",
        "operationId": "chatStream",
        "description": "Streams progress, token chunks, and final result via Server-Sent Events.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SSE stream with event/token/done/error frames",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Validation error before stream starts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/runtime": {
      "get": {
        "summary": "Runtime stats",
        "operationId": "runtimeStats",
        "responses": {
          "200": {
            "description": "Current runtime and worker-pool state",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RuntimeStatsResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ChatRequest": {
        "type": "object",
        "required": [
          "provider",
          "message"
        ],
        "properties": {
          "provider": {
            "type": "string",
            "enum": [
              "cliacp",
              "codex",
              "claude",
              "gemini"
            ],
            "description": "Execution backend. Use cliacp for automatic routing by model id."
          },
          "message": {
            "type": "string"
          },
          "model": {
            "type": "string",
            "description": "Model id (for example: gpt-5.3-codex, claude-sonnet-4-6, gemini-3.1-pro-preview)."
          },
          "cwd": {
            "type": "string",
            "description": "Working directory used by the selected CLI."
          },
          "timeoutMs": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3600000
          },
          "permissionMode": {
            "type": "string",
            "enum": [
              "allow",
              "reject"
            ],
            "default": "allow"
          },
          "reasoningEffort": {
            "type": "string",
            "enum": [
              "none",
              "minimal",
              "low",
              "medium",
              "high",
              "xhigh",
              "max"
            ],
            "description": "Reasoning effort level. Supported values depend on provider/model."
          },
          "includeEvents": {
            "type": "boolean",
            "default": false
          },
          "apiKey": {
            "type": "string",
            "description": "Optional provider API key. When omitted, router uses native CLI auth sessions."
          },
          "baseUrl": {
            "type": "string",
            "description": "Optional upstream API base URL override for Codex/Claude requests."
          },
          "geminiBaseUrl": {
            "type": "string",
            "description": "Optional upstream API base URL override for Gemini requests."
          },
          "mcpServers": {
            "type": "array",
            "description": "Optional ACP MCP servers forwarded to session/new.",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "sessionMode": {
            "type": "string",
            "enum": [
              "stateless",
              "sticky"
            ],
            "default": "stateless",
            "description": "stateless = new conversation each request; sticky = reuse conversation across requests."
          },
          "routerSessionId": {
            "type": "string",
            "description": "Session id returned by a previous sticky response."
          },
          "releaseSession": {
            "type": "boolean",
            "default": false,
            "description": "When true with sticky mode, closes the sticky session after this request."
          }
        }
      },
      "ChatResponse": {
        "type": "object",
        "required": [
          "provider",
          "sessionId",
          "stopReason",
          "outputText",
          "elapsedMs"
        ],
        "properties": {
          "provider": {
            "type": "string"
          },
          "sessionId": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "protocolVersion": {
            "type": "integer"
          },
          "stopReason": {
            "type": "string"
          },
          "outputText": {
            "type": "string"
          },
          "elapsedMs": {
            "type": "integer"
          },
          "updates": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "stderr": {
            "type": "string"
          },
          "routedProvider": {
            "type": "string"
          },
          "routerSessionId": {
            "type": "string"
          },
          "pooled": {
            "type": "boolean"
          },
          "workerId": {
            "type": "string"
          },
          "queuedMs": {
            "type": "integer"
          },
          "createdWorker": {
            "type": "boolean"
          }
        }
      },
      "ProvidersResponse": {
        "type": "object",
        "required": [
          "providers"
        ],
        "properties": {
          "providers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ModelsResponse": {
        "type": "object",
        "required": [
          "object",
          "data"
        ],
        "properties": {
          "object": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "object"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "object": {
                  "type": "string"
                },
                "owned_by": {
                  "type": "string"
                },
                "metadata": {
                  "type": "object",
                  "properties": {
                    "provider": {
                      "type": "string"
                    },
                    "family": {
                      "type": "string"
                    },
                    "source": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "ChatCompletionsRequest": {
        "type": "object",
        "required": [
          "messages"
        ],
        "properties": {
          "model": {
            "type": "string",
            "description": "Model id from /v1/models, for example: gpt-5.3-codex, claude-haiku-4-5, gemini-3.1-pro-preview."
          },
          "provider": {
            "type": "string",
            "enum": [
              "cliacp",
              "codex",
              "claude",
              "gemini"
            ]
          },
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "stream": {
            "type": "boolean"
          },
          "timeoutMs": {
            "type": "integer"
          },
          "permissionMode": {
            "type": "string",
            "enum": [
              "allow",
              "reject"
            ]
          },
          "reasoningEffort": {
            "type": "string",
            "enum": [
              "none",
              "minimal",
              "low",
              "medium",
              "high",
              "xhigh",
              "max"
            ]
          },
          "reasoning": {
            "type": "object",
            "properties": {
              "effort": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "apiKey": {
            "type": "string",
            "description": "Optional provider API key. When omitted, router uses native CLI auth sessions."
          },
          "baseUrl": {
            "type": "string",
            "description": "Optional upstream API base URL override for Codex/Claude requests."
          },
          "geminiBaseUrl": {
            "type": "string",
            "description": "Optional upstream API base URL override for Gemini requests."
          },
          "mcpServers": {
            "type": "array",
            "description": "Optional ACP MCP servers forwarded to session/new.",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "sessionMode": {
            "type": "string",
            "enum": [
              "stateless",
              "sticky"
            ]
          },
          "routerSessionId": {
            "type": "string",
            "description": "Session id returned by a previous sticky response."
          },
          "releaseSession": {
            "type": "boolean",
            "description": "When true with sticky mode, closes the sticky session after this request."
          },
          "promptCacheKey": {
            "type": "string",
            "description": "External session key used to auto-map requests to a sticky router session."
          }
        }
      },
      "ChatCompletionsResponse": {
        "type": "object",
        "required": [
          "id",
          "object",
          "model",
          "choices"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "object": {
            "type": "string"
          },
          "created": {
            "type": "integer"
          },
          "model": {
            "type": "string"
          },
          "choices": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      },
      "ResponsesRequest": {
        "type": "object",
        "properties": {
          "model": {
            "type": "string",
            "description": "Model id from /v1/models."
          },
          "provider": {
            "type": "string",
            "enum": [
              "cliacp",
              "codex",
              "claude",
              "gemini"
            ],
            "description": "Execution backend. Use cliacp for automatic routing by model id."
          },
          "input": {
            "description": "String or structured input payload.",
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array"
              }
            ]
          },
          "stream": {
            "type": "boolean"
          },
          "reasoningEffort": {
            "type": "string",
            "enum": [
              "none",
              "minimal",
              "low",
              "medium",
              "high",
              "xhigh",
              "max"
            ]
          },
          "reasoning": {
            "type": "object",
            "properties": {
              "effort": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "apiKey": {
            "type": "string",
            "description": "Optional provider API key. When omitted, router uses native CLI auth sessions."
          },
          "baseUrl": {
            "type": "string",
            "description": "Optional upstream API base URL override for Codex/Claude requests."
          },
          "geminiBaseUrl": {
            "type": "string",
            "description": "Optional upstream API base URL override for Gemini requests."
          },
          "mcpServers": {
            "type": "array",
            "description": "Optional ACP MCP servers forwarded to session/new.",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "sessionMode": {
            "type": "string",
            "enum": [
              "stateless",
              "sticky"
            ]
          },
          "routerSessionId": {
            "type": "string",
            "description": "Session id returned by a previous sticky response."
          },
          "releaseSession": {
            "type": "boolean",
            "description": "When true with sticky mode, closes the sticky session after this request."
          },
          "promptCacheKey": {
            "type": "string",
            "description": "External session key used to auto-map requests to a sticky router session."
          }
        }
      },
      "ResponsesResult": {
        "type": "object",
        "required": [
          "id",
          "object",
          "output_text"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "object": {
            "type": "string"
          },
          "created_at": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "output_text": {
            "type": "string"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "ok",
          "service"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "service": {
            "type": "string"
          },
          "runtime": {
            "$ref": "#/components/schemas/RuntimeStatsResponse"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          },
          "details": {
            "type": "string"
          }
        }
      },
      "RuntimeStatsResponse": {
        "type": "object",
        "properties": {
          "pool": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  }
}
